---
import type { ChordShape } from "../lib/chords";

interface Props {
  chord: ChordShape;
  /** Visual size in pixels (height of the fretboard). Default 96. */
  size?: number;
  /** When true, hide the variant label (barre/easy) under the name. */
  hideVariant?: boolean;
  /** Optional aria-label override. */
  ariaLabel?: string;
}

const { chord, size = 96, hideVariant = false, ariaLabel } = Astro.props;

// Geometry constants (px). Width is derived from string count.
const STRINGS = 6;
const STRING_GAP = 14;
const PADDING_X = 14;
const FRET_HEIGHT = 16;
const FRET_PAD_TOP = 24;   // space for open/muted labels + nut
const FRET_PAD_BOT = 12;   // space for fret number under the diagram
const NUT_HEIGHT = 3;

const width = PADDING_X * 2 + STRING_GAP * (STRINGS - 1);
const height = FRET_PAD_TOP + FRET_HEIGHT * 5 + FRET_PAD_BOT;

// Determine the fret range to display.
const positiveFrets = chord.frets.filter((f) => f > 0);
const maxFret = positiveFrets.length ? Math.max(...positiveFrets) : 1;
const baseFret = chord.baseFret ?? 1;
const showBaseFretLabel = baseFret > 1 || maxFret > 4;

// If baseFret is set high (e.g. barre shape), display window may need 5 frets.
const windowFrets = 5;

const x = (i: number) => PADDING_X + i * STRING_GAP;
const y = (fret: number) =>
  FRET_PAD_TOP + (fret - baseFret + 1) * FRET_HEIGHT - FRET_HEIGHT / 2;

const stringLabel = (f: number) => (f === -1 ? "x" : f === 0 ? "○" : "");
---

<figure
  class="chord"
  style={`--chord-h: ${size}px;`}
  aria-label={ariaLabel ?? `${chord.name} chord diagram`}
>
  <figcaption class="chord__name">
    <span class="chord__name-text">{chord.name}</span>
    {!hideVariant && chord.variant && (
      <span class="chord__variant">{chord.variant}</span>
    )}
  </figcaption>

  <svg
    class="chord__svg"
    viewBox={`0 0 ${width} ${height}`}
    width={width}
    height={height}
    role="img"
    aria-hidden="true"
  >
    {/* Top label row: open/muted per string */}
    {chord.frets.map((f, i) => (
      <text
        x={x(i)}
        y={FRET_PAD_TOP - 10}
        text-anchor="middle"
        class={`chord__stringlabel ${f === 0 ? "is-open" : f === -1 ? "is-muted" : ""}`}
      >
        {stringLabel(f)}
      </text>
    ))}

    {/* Nut (only when starting at fret 1) */}
    {baseFret === 1 && (
      <rect
        x={PADDING_X}
        y={FRET_PAD_TOP}
        width={STRING_GAP * (STRINGS - 1)}
        height={NUT_HEIGHT}
        fill="var(--ink)"
      />
    )}

    {/* Fret lines */}
    {Array.from({ length: windowFrets + 1 }, (_, i) => i).map((i) => (
      <line
        x1={PADDING_X}
        x2={PADDING_X + STRING_GAP * (STRINGS - 1)}
        y1={FRET_PAD_TOP + i * FRET_HEIGHT}
        y2={FRET_PAD_TOP + i * FRET_HEIGHT}
        stroke="var(--ink)"
        stroke-width={i === 0 && baseFret === 1 ? 0 : 1}
      />
    ))}

    {/* String lines */}
    {Array.from({ length: STRINGS }, (_, i) => i).map((i) => (
      <line
        x1={x(i)}
        x2={x(i)}
        y1={FRET_PAD_TOP}
        y2={FRET_PAD_TOP + windowFrets * FRET_HEIGHT}
        stroke="var(--ink)"
        stroke-width={1.1}
        opacity={0.85}
      />
    ))}

    {/* Barre */}
    {chord.barre && (() => {
      const { fret, from, to } = chord.barre;
      const yBar = FRET_PAD_TOP + (fret - baseFret + 1) * FRET_HEIGHT - FRET_HEIGHT / 2;
      const x1 = x(from) - 6;
      const x2 = x(to) + 6;
      return (
        <line
          x1={x1}
          x2={x2}
          y1={yBar}
          y2={yBar}
          stroke="var(--ink)"
          stroke-width={9}
          stroke-linecap="round"
          opacity={0.92}
        />
      );
    })()}

    {/* Dots */}
    {chord.frets.map((f, i) => ({ f, i }))
      .filter(({ f }) => f > 0)
      .map(({ f, i }) => {
        const cx = x(i);
        const cy = y(f);
        const finger = chord.fingers?.[i];
        const showFinger = finger !== undefined && finger !== null && finger > 0;
        return (
          <Fragment>
            <circle cx={cx} cy={cy} r={6.4} fill="var(--blood)" />
            {showFinger && (
              <text
                x={cx}
                y={cy + 3.5}
                text-anchor="middle"
                class="chord__finger"
              >
                {finger}
              </text>
            )}
          </Fragment>
        );
      })}

    {/* Base fret label */}
    {showBaseFretLabel && (
      <text
        x={PADDING_X - 4}
        y={FRET_PAD_TOP + FRET_HEIGHT * 1.4}
        text-anchor="end"
        class="chord__baseref"
      >
        {baseFret}fr
      </text>
    )}
  </svg>
</figure>

<style>
  .chord {
    --chord-h: 96px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: .15rem;
    margin: 0;
  }
  .chord__name {
    display: inline-flex;
    align-items: baseline;
    gap: .35rem;
    line-height: 1;
  }
  .chord__name-text {
    font-family: var(--display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
    letter-spacing: -.01em;
  }
  .chord__variant {
    font-family: var(--mono);
    font-size: .55rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--blood);
  }
  .chord__svg {
    height: var(--chord-h);
    width: auto;
  }
  .chord__stringlabel {
    font-family: var(--mono);
    font-size: 11px;
    fill: var(--ink);
  }
  .chord__stringlabel.is-open { fill: var(--paper); }
  .chord__stringlabel.is-muted { fill: var(--ink-soft); }
  .chord__finger {
    font-family: var(--mono);
    font-size: 9px;
    fill: var(--paper);
    font-weight: 700;
  }
  .chord__baseref {
    font-family: var(--mono);
    font-size: 9px;
    fill: var(--ink-fade);
    letter-spacing: .04em;
  }
</style>
