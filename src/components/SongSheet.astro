---
import type { Song, SongSection } from "../lib/song";
import { CHORD_LIBRARY } from "../lib/chords";
import ChordLine from "./ChordLine.astro";
import ChordBar from "./ChordBar.astro";
import ResourceLinks from "./ResourceLinks.astro";

interface Props {
  song: Song;
}

const { song } = Astro.props;

// Resolve chord names to full shapes for the ChordBar
const chordShapes = song.chords_used
  .map((name) => CHORD_LIBRARY[name])
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const SECTION_LABEL: Record<SongSection["kind"], string> = {
  intro: "Intro",
  verse: "Verse",
  chorus: "Chorus",
  "pre-chorus": "Pre-chorus",
  bridge: "Bridge",
  solo: "Solo",
  interlude: "Interlude",
  outro: "Outro",
  spoken: "Spoken",
};

const NUMBERED_KINDS: SongSection["kind"][] = ["verse", "chorus", "pre-chorus", "bridge"];
const seenCounters = new Map<string, number>();

function sectionHeading(section: SongSection) {
  if (section.label) return section.label;
  const base = SECTION_LABEL[section.kind] ?? section.kind;
  if (!NUMBERED_KINDS.includes(section.kind)) return base;
  const key = section.kind;
  const n = (seenCounters.get(key) ?? 0) + 1;
  seenCounters.set(key, n);
  return `${base} ${n}`;
}

seenCounters.clear();
---

<article class="sheet">
  <header class="sheet__head">
    <p class="sheet__eyebrow">
      {song.artist}
      {song.album && <><span aria-hidden="true"> · </span>{song.album}</>}
      {song.year && <><span aria-hidden="true"> · </span>{song.year}</>}
    </p>
    <h1 class="sheet__title">
      <span class="sheet__title-text">{song.title}</span>
    </h1>
    <dl class="sheet__facts" aria-label="Song facts">
      {song.key && (<div><dt>Key</dt><dd>{song.key}</dd></div>)}
      {song.tempo_bpm && (<div><dt>Tempo</dt><dd>♩ = {song.tempo_bpm}</dd></div>)}
      {song.time_signature && (<div><dt>Time</dt><dd>{song.time_signature}</dd></div>)}
      {song.tuning && (<div><dt>Tuning</dt><dd>{song.tuning}</dd></div>)}
      {song.capo !== undefined && (<div><dt>Capo</dt><dd>{song.capo === 0 ? "—" : `fret ${song.capo}`}</dd></div>)}
    </dl>
  </header>

  <ChordBar chords={chordShapes} sticky={true} />

  {song.resources && song.resources.length > 0 && (
    <ResourceLinks resources={song.resources} />
  )}

  <section class="sheet__body">
    {song.sections.map((section, idx) => (
      <div class={`section section--${section.kind}`} data-section={section.kind}>
        <h3 class="section__label">
          <span class="section__num">{String(idx + 1).padStart(2, "0")}</span>
          <span class="section__name">{sectionHeading(section)}</span>
          <span class="section__rule" aria-hidden="true"></span>
        </h3>
        <div class="section__lines">
          {section.lines.map((line) => (
            <ChordLine
              text={line.text}
              chords={line.chords}
              repeat={line.repeat}
              progressionOnly={["intro", "interlude", "solo", "outro"].includes(section.kind)}
            />
          ))}
        </div>
      </div>
    ))}
  </section>

  {song.source && (
    <footer class="sheet__foot">
      <a href={song.source.url} rel="noopener noreferrer" target="_blank">
        Source: {song.source.label} ↗
      </a>
    </footer>
  )}
</article>

<style>
  .sheet {
    --gutter-x: clamp(0.5rem, 2vw, 1.5rem);
    position: relative;
  }

  .sheet__head {
    display: grid;
    gap: .55rem;
    padding-block: .5rem 1.25rem;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 0;
  }
  .sheet__eyebrow {
    font-family: var(--mono);
    font-size: .72rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--ink-fade);
  }
  .sheet__title {
    font-family: var(--display);
    font-weight: 700;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
    line-height: .92;
    letter-spacing: -.025em;
    margin: 0;
  }
  .sheet__title-text {
    font-size: clamp(2.5rem, 7vw, 5rem);
    display: inline-block;
  }
  .sheet__title-text::after {
    content: "";
    display: block;
    width: 3.5rem;
    height: 6px;
    background: var(--blood);
    margin-top: .35rem;
  }

  .sheet__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem 1.5rem;
    margin: .75rem 0 0;
  }
  .sheet__facts div {
    display: contents;
  }
  .sheet__facts dt {
    font-family: var(--mono);
    font-size: .62rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-fade);
    margin-right: .35rem;
  }
  .sheet__facts dd {
    display: inline;
    margin: 0;
    font-family: var(--mono);
    font-size: .82rem;
    color: var(--ink);
  }
  .sheet__facts dd::after {
    content: "";
    display: block;
  }

  .sheet__body { margin-top: 1.25rem; }

  .section { margin-bottom: 2.25rem; }
  .section__label {
    display: flex;
    align-items: center;
    gap: .85rem;
    margin-bottom: .8rem;
    font-family: var(--display);
    font-weight: 600;
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1;
  }
  .section__num {
    font-family: var(--mono);
    font-style: normal;
    font-size: .65rem;
    letter-spacing: .2em;
    color: var(--blood);
    border: 1.5px solid var(--blood);
    padding: .25rem .45rem;
    line-height: 1;
  }
  .section__rule {
    flex: 1;
    height: 1px;
    background:
      linear-gradient(to right, var(--ink) 0 60%, transparent 60% 70%, var(--ink) 70% 75%, transparent 75% 100%);
    background-size: 9px 1px;
    background-repeat: repeat-x;
  }
  .section--chorus .section__num { color: var(--paper); background: var(--blood); border-color: var(--blood); }
  .section--solo .section__num { color: var(--paper); background: var(--blue); border-color: var(--blue); }
  .section--interlude .section__num { color: var(--paper); background: var(--ink); border-color: var(--ink); }
  .section--intro .section__num { color: var(--paper); background: var(--ink); border-color: var(--ink); }

  .section__lines {
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-inline: .15rem;
    background:
      repeating-linear-gradient(
        to bottom,
        transparent 0,
        transparent 30px,
        rgba(122, 111, 93, .06) 30px,
        rgba(122, 111, 93, .06) 31px
      );
  }

  .sheet__foot {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }
  .sheet__foot a {
    font-family: var(--mono);
    font-size: .75rem;
    color: var(--ink-fade);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .sheet__foot a:hover { color: var(--blood); }

  @media (max-width: 760px) {
    .sheet__title-text { font-size: clamp(2.2rem, 9vw, 3.4rem); }
    .section { margin-bottom: 1.75rem; }
    .section__label { font-size: 1.15rem; }
  }
</style>
