    '<path d="M3 3h13v2H3zm0 4h13v2H3zm0 4h9v2H3zm0 4h13v2H3z"/><path d="M19 3l-1 2h-1v2h2v12h2V3z"/>',
  wikipedia:
    '<text x="12" y="18" text-anchor="middle" font-family="serif" font-size="16" font-weight="700">W</text>',
  official:
    '<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M3 12h18M12 3a13 13 0 0 1 0 18M12 3a13 13 0 0 0 0 18" fill="none" stroke="currentColor" stroke-width="1.2"/>',
  musicbrainz:
    '<circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" fill="currentColor"/><circle cx="12" cy="12" r="6.5" fill="none" stroke="currentColor" stroke-width="1"/>',
  discogs:
    '<circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" fill="currentColor"/>',
  other:
    '<path d="M10 13a5 5 0 0 0 7.07 0l3.18-3.18a5 5 0 0 0-7.07-7.07l-1.59 1.59M14 11a5 5 0 0 0-7.07 0L3.75 14.18a5 5 0 0 0 7.07 7.07l1.59-1.59" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
};

function labelFor(r: Resource): string {
  if (r.label && r.label.trim()) return r.label;
  return TYPE_LABEL[r.type] ?? r.type;
}
---

{resources && resources.length > 0 && (
  <section class="resources" aria-label="External resources">
    <h3 class="resources__h">Resources</h3>
    <ul class="resources__list">
      {resources.map((r) => (
        <li>
          <a
            class={`resource resource--${r.type}`}
            href={r.url}
            target="_blank"
            rel="noopener noreferrer"
            title={labelFor(r)}
          >
            <svg
              class="resource__icon"
              viewBox="0 0 24 24"
              width="14"
              height="14"
              aria-hidden="true"
              set:html={`<g>${ICON[r.type] ?? ICON.other}</g>`}
            />
            <span class="resource__label">{labelFor(r)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .resources {
    margin: 1.25rem 0 0;
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    border-left: 4px solid var(--blood);
    background: var(--paper);
  }
  .resources__h {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-fade);
    margin: 0 0 0.55rem;
    font-weight: 500;
  }
  .resources__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .resource {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    line-height: 1;
    text-decoration: none;
    transition: border-color var(--t-fast) var(--ease), color var(--t-fast) var(--ease), transform var(--t-fast) var(--ease);
  }
  .resource:hover {
    border-color: var(--blood);
    color: var(--blood);
    transform: translateY(-1px);
  }
  .resource__icon {
    color: var(--ink-soft);
    fill: currentColor;
    flex: 0 0 auto;
  }
  .resource:hover .resource__icon {
    color: var(--blood);
  }
  .resource--youtube .resource__icon,
  .resource--youtube_music .resource__icon {
    color: #d10028;
  }
  .resource--spotify .resource__icon {
    color: #1db954;
  }
  .resource--apple_music .resource__icon {
    color: #fa243c;
  }
  .resource--bandcamp .resource__icon {
    color: #1da0c3;
  }
  .resource--soundcloud .resource__icon {
    color: #ff5500;
  }
  .resource__label {
    white-space: nowrap;
  }
</style>
