---
/** Compact row of resource links for a song. YouTube, Spotify, lyrics, wiki... */
import type { Resource, ResourceType } from "../lib/song";

interface Props {
  resources: Resource[];
}

const { resources } = Astro.props;

if (!resources || resources.length === 0) {
  // Render nothing
}

const TYPE_LABEL: Record<ResourceType, string> = {
  youtube: "YouTube",
  youtube_music: "YouTube Music",
  spotify: "Spotify",
  apple_music: "Apple Music",
  tidal: "Tidal",
  bandcamp: "Bandcamp",
  soundcloud: "SoundCloud",
  lyrics: "Lyrics",
  wikipedia: "Wikipedia",
  official: "Official",
  musicbrainz: "MusicBrainz",
  discogs: "Discogs",
  other: "Link",
};

const TYPE_COLOR: Record<ResourceType, string> = {
  youtube: "#ff0033",
  youtube_music: "#ff0033",
  spotify: "#1db954",
  apple_music: "#fa243c",
  tidal: "#000000",
  bandcamp: "#1da0c3",
  soundcloud: "#ff5500",
  lyrics: "#5a78b4",
  wikipedia: "#5a5a5a",
  official: "#b48a2c",
  musicbrainz: "#5a78b4",
  discogs: "#2a2520",
  other: "#5a5a5a",
};

