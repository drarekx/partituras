    '<path d="M23.994 6.124a9.23 9.23 0 0 0-.24-2.13c-.13-.5-.41-1.01-.86-1.36-.41-.32-.89-.5-1.39-.5-1.66 0-3.32-.01-4.98 0-.62 0-1.25.18-1.79.55-.49.34-.79.88-.95 1.43-.1.36-.14.74-.16 1.11-.04.69-.01 1.38-.02 2.07v9.71c-.79.32-1.61.55-2.45.69-1.16.21-2.34.21-3.5.02-1.07-.18-2.04-.6-2.84-1.27-.79-.66-1.38-1.52-1.6-2.49-.31-1.32-.13-2.7.61-3.86.62-.97 1.6-1.69 2.71-2.07 1.32-.45 2.74-.5 4.11-.29 0-.18.01-.36 0-.54V5.79c-.03-.49-.34-.95-.83-1.07-1.31-.34-2.69-.4-4.04-.31-1.61.1-3.22.43-4.69 1.13C.74 6.4.04 7.45 0 8.62c-.02.74.07 1.49.27 2.2.41 1.46 1.27 2.79 2.49 3.65 1.59 1.13 3.55 1.59 5.45 1.59.29 0 .57-.01.86-.04v3.32c-.93.21-1.87.45-2.78.74-1.18.38-2.34.88-3.34 1.62-1.5 1.11-2.51 2.78-2.62 4.59-.07 1.13.13 2.27.69 3.27.86 1.55 2.41 2.7 4.11 3.24 1.81.58 3.75.6 5.6.27 1.83-.32 3.55-1.06 5.08-2.1.04-.03.07-.06.11-.09.13-2.27.27-4.54.4-6.81 0-.11.04-.21.11-.27z"/>',
