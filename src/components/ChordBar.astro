---
import ChordDiagram from "./ChordDiagram.astro";
import type { ChordShape } from "../lib/chords";

interface Props {
  chords: ChordShape[];
  /** When true, the bar is `position: sticky` under the page header. */
  sticky?: boolean;
}

const { chords, sticky = true } = Astro.props;
---

<section
  class:list={["chordbar", sticky && "chordbar--sticky"]}
  aria-label="Chord shapes used in this song"
>
  <p class="chordbar__label">Chords</p>
  <ol class="chordbar__list" role="list">
    {chords.map((c) => (
      <li class="chordbar__cell">
        <ChordDiagram chord={c} size={84} />
      </li>
    ))}
  </ol>
</section>

<style>
  .chordbar {
    margin-block: 1.25rem 1.5rem;
    padding: .85rem 1rem .65rem;
    background: var(--paper-deep);
    border: 1px solid var(--ink);
    border-radius: 2px;
    box-shadow: 4px 4px 0 0 rgba(24, 20, 16, 0.08);
  }
  .chordbar--sticky {
    position: sticky;
    top: var(--topbar-h);
    z-index: 5;
    backdrop-filter: blur(6px);
    background:
      linear-gradient(180deg, rgba(230, 222, 199, .96), rgba(230, 222, 199, .92));
  }
  .chordbar__label {
    font-family: var(--mono);
    font-size: .65rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ink-fade);
    margin-bottom: .55rem;
  }
  .chordbar__list {
    display: flex;
    flex-wrap: nowrap;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: .25rem;
    scrollbar-width: thin;
  }
  .chordbar__cell {
    flex: 0 0 auto;
    min-width: 5.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: .25rem .35rem;
    background: rgba(255, 255, 255, .45);
    border: 1px solid var(--rule);
    border-radius: 2px;
  }
</style>
