---
import ChordDiagram from "./ChordDiagram.astro";
import type { ChordShape } from "../lib/chords";

interface Props {
  chords: ChordShape[];
  /** When true, the bar is `position: sticky` under the page header. */
  sticky?: boolean;
}

const { chords, sticky = true } = Astro.props;
---

<section
  class:list={["chordbar", sticky && "chordbar--sticky"]}
  aria-label="Acords usats en aquesta cançó"
>
  <p class="chordbar__label">Acords</p>
  <ol class="chordbar__list" role="list">
    {chords.map((c) => (
      <li class="chordbar__cell">
        <ChordDiagram chord={c} size={84} />
      </li>
    ))}
  </ol>
</section>

<style>
  .chordbar {
    margin-block: 1.25rem 1.5rem;
    padding: .85rem 1rem .65rem;
    background: var(--paper-deep);
    border: 1.5px solid var(--ink);
    border-radius: 2px;
    box-shadow: 4px 4px 0 0 rgba(21, 49, 90, 0.08);
  }
  .chordbar--sticky {
    position: sticky;
    top: var(--topbar-h);
    z-index: 5;
    backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.95);
  }
  .chordbar__label {
    font-family: var(--hand);
    font-size: .95rem;
    font-style: italic;
    color: var(--ink-fade);
    margin-bottom: .55rem;
  }
  .chordbar__label::before { content: "› "; color: var(--blue); }
  .chordbar__list {
    display: flex;
    flex-wrap: nowrap;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: .25rem;
    scrollbar-width: thin;
  }
  .chordbar__cell {
    flex: 0 0 auto;
    min-width: 5.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: .25rem .35rem;
    background: var(--paper);
    border: 1.5px solid var(--rule);
    border-radius: 2px;
  }
</style>
