---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Cancçoner de guitarres — fulls quadriculats amb acords, lletres i progressions." } = Astro.props;
const fullTitle = title === "Cancçoner" ? "Cancçoner" : `${title} · Cancçoner`;
---

<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <title>{fullTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Kalam:wght@300;400;700&family=Caveat:wght@400;600;700&family=JetBrains+Mono:wght@400..700&display=swap"
    />

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23ffffff'/%3E%3Cg fill='none' stroke='%2315315a' stroke-width='2'%3E%3Cpath d='M9 7v18M23 7v18'/%3E%3Cpath d='M9 11h14M9 21h14'/%3E%3C/g%3E%3C/svg%3E" />
  </head>

  <body>
    <header class="topbar">
      <div class="topbar__inner wrap">
        <a href="/" class="topbar__brand" aria-label="Cancçoner — inici">
          <svg viewBox="0 0 40 40" width="30" height="30" aria-hidden="true">
            <circle cx="14" cy="26" r="6" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="26" cy="22" r="6" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M14 26 L26 22 L26 8 L14 12 Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          </svg>
          <span class="topbar__brand-text">Cancçoner</span>
        </a>
        <nav class="topbar__nav" aria-label="Principal">
          <slot name="nav" />
          <a href="/chords/" class="topbar__link">Acords</a>
          <a href="/" class="topbar__link">Cançons</a>
        </nav>
      </div>
    </header>

    <main class="wrap main">
      <slot />
    </main>

    <style>
      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(8px);
        border-bottom: 1.5px solid var(--ink);
      }
      .topbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-block: .85rem;
      }
      .topbar__brand {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        color: var(--ink);
        font-family: var(--display);
        font-weight: 700;
        font-size: 1.5rem;
        letter-spacing: -.01em;
      }
      .topbar__brand-text {
        line-height: 1;
        font-style: italic;
      }
      .topbar__nav {
        display: inline-flex;
        align-items: center;
        gap: 1.25rem;
      }
      .topbar__link {
        font-family: var(--hand);
        font-size: 1.1rem;
        letter-spacing: .01em;
        color: var(--ink-soft);
        font-weight: 500;
        transition: color var(--t-fast) var(--ease);
      }
      .topbar__link:hover {
        color: var(--blue);
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 4px;
        text-decoration-style: wavy;
      }

      .main {
        padding-block: 1.25rem 3rem;
      }

      @media (max-width: 540px) {
        .topbar__inner { padding-block: .65rem; }
        .topbar__brand { font-size: 1.3rem; }
        .topbar__nav { gap: 1rem; }
        .topbar__link { font-size: 1rem; }
      }
    </style>
  </body>
</html>
