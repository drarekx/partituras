  "sections": [
    {
      "kind": "verse",
      "label": "Estrofa 1",
      "lines": [
        {
          "text": "Después de un año de no ver tierra",
          "chords": [
            {
              "name": "D",
              "at": 0
            }
          ]
        },
        {
          "text": "porque la guerra me lo impidió,",
          "chords": [
            {
              "name": "B7",
              "at": 0
            },
            {
              "name": "A7",
              "at": 2
            }
          ]
        },
        {
          "text": "me fui al puerto donde se hallaba",
          "chords": [
            {
              "name": "D",
              "at": 0
            }
          ]
        },
        {
          "text": "la que adoraba mi corazón.",
          "chords": [
            {
              "name": "A7",
              "at": 0
            },
            {
              "name": "D",
              "at": 10
            }
          ]
        }
      ]
    },
    {
      "kind": "chorus",
      "label": "Estribillo 1",
      "lines": [
        {
          "text": "Ay !  que placer sentía yo,",
          "chords": [
            {
              "name": "A7",
              "at": 0
            },
            {
              "name": "D",
              "at": 10
            }
          ]
        },
        {
          "text": "cuando en la playa",
          "chords": [
            {
              "name": "A7",
              "at": 0
            }
          ]
        },
        {
          "text": "sacó el pañuelo y me saludó,",
          "chords": [
            {
              "name": "D",
              "at": 0
            }
          ]
        },
        {
          "text": "luego después se acercó a mi,",
          "chords": [
            {
              "name": "A7",
              "at": 0
            },
            {
              "name": "D",
              "at": 14
            },
            {
              "name": "B7",
              "at": 19
            }
          ]
        },
        {
          "text": "me dio un abrazo,",
          "chords": [
            {
              "name": "Em",
              "at": 0
            }
          ]
        },
        {
          "text": "y en aquel lazo creí morir.",
          "chords": [
            {
              "name": "A7",
              "at": 0
            },
            {
              "name": "D",
              "at": 11
            }
          ]
        }
      ]
    },
    {
      "kind": "chorus",
      "label": "Tornada",
      "lines": [
        {
          "text": "Cuando en la playa, la bella Lola,",
          "chords": [
            {
              "name": "D",
              "at": 0
            }
          ]
        },
        {
          "text": "su larga cola luciendo va,",
          "chords": [
            {
              "name": "B7",
              "at": 0
            },
            {
              "name": "A7",
              "at": 2
            }
          ]
        },
        {
          "text": "los marineros se vuelven locos",
          "chords": [
            {
              "name": "D",
              "at": 0
            }
          ]
        },
        {
          "text": "y hasta el piloto pierde el compás.",
